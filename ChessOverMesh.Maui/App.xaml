<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:ChessOverMesh.Maui"
             x:Class="ChessOverMesh.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <!-- App-wide text size for buttons/labels/inputs (window chrome). The chat/moves/system content
                 lines bind their own FontSize, so they keep their independent sizes. Seeded from AppSettings
                 at startup and updated live when changed. -->
            <x:Double x:Key="UiTextSize">14</x:Double>
        </ResourceDictionary>
    </Application.Resources>
</Application>
